# ===================================================================
# WILLOWCMS CONFIG ENVIRONMENT FILE
# ===================================================================
# This file is loaded by the Docker containers as specified in docker-compose.yml
# Standard .env format for Docker Compose (KEY=value)
# ===================================================================
# UID and GID are handled automatically by Docker Compose
# COMPOSE_UID=501
# COMPOSE_GID=20

# ===================================================================
# APPLICATION CONFIGURATION
# ===================================================================
# Application name displayed throughout the CMS interface
APP_NAME=WillowCMS

# TAG=v1.5.0-beta

# Debug mode - IMPORTANT: Set to 'false' in production environments
DEBUG=true

# Character encoding for the application - UTF-8 is recommended
APP_ENCODING=UTF-8

# Default locale/language for the application interface
APP_DEFAULT_LOCALE=en_GB

# Default timezone for date/time operations
APP_DEFAULT_TIMEZONE=Europe/London

# Security salt for encryption - CRITICAL: Generate a unique 64-character string
# Use a secure generator like: https://www.grc.com/passwords.htm
# This MUST be changed from the default value for security
SECURITY_SALT=development_salt_12345678901234567890123456789012345678901234567890

# ===================================================================
# MYSQL ROOT CONFIGURATION
# ===================================================================
# MySQL root password for initial database setup

MYSQL_ROOT_PASSWORD=password
# ===================================================================
# PRIMARY DATABASE CONFIGURATION
# ===================================================================
# Database host - use service name from docker-compose (typically 'mysql')
DB_HOST=mysql
# Database name for your CMS
DB_DATABASE=cms
# Database username (create a specific user, don't use root for applications)
DB_USERNAME=cms_user

# Database password - use a strong, unique password
DB_PASSWORD=password

# Database port (MySQL default is 3306)
DB_PORT=3306

# ===================================================================
# TEST DATABASE CONFIGURATION
# ===================================================================
# Separate database configuration for running automated tests
TEST_DB_HOST=mysql
TEST_DB_DATABASE=cms_test
TEST_DB_USERNAME=cms_user_test
TEST_DB_PASSWORD=password
TEST_DB_PORT=3306

# ===================================================================
# EMAIL/SMTP CONFIGURATION
# ===================================================================
# Email server host (mailpit for development, your SMTP server for production)
EMAIL_HOST=mailpit

# Email server port (1025 for mailpit, 587/465 for production SMTP)
EMAIL_PORT=1025

# Connection timeout in seconds
EMAIL_TIMEOUT=30

# SMTP authentication credentials (leave empty for development with mailpit)
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Email addresses for replies and no-reply messages
EMAIL_REPLY=hello@willowcms.me
EMAIL_NOREPLY=noreply@willowcms.me

# ===================================================================
# REDIS CONFIGURATION (FOR WILLOWCMS)
# ===================================================================
# Redis server host
# Redis server port
REDIS_PORT=6379

# Redis database number (0-15, use different numbers for different environments)
# 0 - default
# 1 - testing
# 2 - staging
# 3 - production
REDIS_DATABASE=0

# Redis authentication (uncomment and configure if your Redis requires auth)

REDIS_USERNAME=root
REDIS_PASSWORD=root
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_USERNAME}:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
REDIS_TEST_URL=redis://${REDIS_USERNAME}:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ===================================================================
# EXTERNAL API INTEGRATION
# ===================================================================
# YouTube Data API key for video-related features
# Get your key from: https://console.developers.google.com/
YOUTUBE_API_KEY=

# Google Translate API key for internationalization features
# Get your key from: https://cloud.google.com/translate/
TRANSLATE_API_KEY=AIzaSyCutj6Yu1d-N1A-MhkmBRhqZk-3_tV2weU

# ===================================================================
# QUEUE SYSTEM CONFIGURATION
# ===================================================================
# Background job queue URLs (typically uses Redis)
QUEUE_DEFAULT_URL=redis://root:root@127.0.0.1:6379/0
QUEUE_TEST_URL=redis://root:root@127.0.0.1:6379/0

# ===================================================================
# ADMIN USER CONFIGURATION
# ===================================================================
# Default admin user credentials for initial setup
WILLOW_ADMIN_USERNAME=admin
WILLOW_ADMIN_PASSWORD=password
WILLOW_ADMIN_EMAIL=admin@test.com


# ===================================================================
# PHPMYADMIN CONFIGURATION
# ===================================================================
PMA_HOST=db
PMA_USER=root
PMA_PASSWORD=password
UPLOAD_LIMIT=1024M

# ===================================================================
# JENKINS CONFIGURATION
# ===================================================================
JAVA_OPTS=-Djenkins.install.runSetupWizard=false

# ===================================================================
# MAILPIT CONFIGURATION
# ===================================================================
MP_MAX_MESSAGES=5000
MP_DATABASE=/data/mailpit.db
MP_SMTP_AUTH_ACCEPT_ANY=1
MP_SMTP_AUTH_ALLOW_INSECURE=1

# ===================================================================
# REDIS COMMANDER CONFIGURATION
# ===================================================================
HTTP_USER=root
HTTP_PASSWORD=root
REDIS_COMMANDER_USERNAME=root
REDIS_COMMANDER_HOST=redis
REDIS_COMMANDER_PORT=6379
REDIS_COMMANDER_PASSWORD=root
# ===================================================================
# APPLICATION BASE URL
# ====================================================================
APP_FULL_BASE_URL=http://localhost:8080

# ===================================================================
# TESTING AND DEVELOPMENT
# ===================================================================
# Enable or disable experimental test features
EXPERIMENTAL_TESTS=Off

# ===================================================================
# SECURITY NOTES
# ===================================================================
# 1. Never commit this file with real credentials to version control
# 2. Use strong, unique passwords for all services
# 3. Regularly rotate API keys and passwords
# 4. Set DEBUG to false in production environments
# 5. Use HTTPS in production (configure APP_FULL_BASE_URL accordingly)
# 6. Regularly update the SECURITY_SALT
# ===================================================================



